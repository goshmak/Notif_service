# =============================================================================
# Notification Module -- ANO VO "Humanitarian University"
#
# The application loads variables from .env automatically via pydantic-settings.
# All variables are optional and fall back to the defaults shown below.
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# For the prototype: leave as SQLite.
# For production: switch to PostgreSQL with asyncpg.
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./notifications.db
# DATABASE_URL=postgresql+asyncpg://postgres:secret@localhost:5432/notifications_db

# Print all SQL statements to stdout (useful for debugging, disable in production)
DB_ECHO=false


# -----------------------------------------------------------------------------
# Redis
# Redis must be running before starting the application or worker.
# Default: Redis on localhost port 6379, database 0.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=notifications


# -----------------------------------------------------------------------------
# Worker settings
# -----------------------------------------------------------------------------
# Number of concurrent notification coroutines inside one worker process
WORKER_CONCURRENCY=4

# Maximum delivery attempts per notification before marking it FAILED
MAX_RETRY_ATTEMPTS=5

# Base delay for exponential backoff: delay = RETRY_BASE_DELAY ^ attempt_number (seconds)
RETRY_BASE_DELAY=2.0


# -----------------------------------------------------------------------------
# Email (SMTP)
# Tested with Yandex Mail (smtp.yandex.ru:465)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=gosh.maksimov2017@yandex.ru
SMTP_PASSWORD=demlllztxyjfdggj
SMTP_FROM_NAME=Humanitarian University
SMTP_FROM_EMAIL=gosh.maksimov2017@yandex.ru


# -----------------------------------------------------------------------------
# VK API
# 1. Create or open your VK community: https://vk.com/groups
# 2. Go to Manage -> API usage -> Create token
# 3. Enable "Allow messages from community" in community settings -> Messages
# 4. VK_GROUP_ID is the numeric ID shown in the community URL
# -----------------------------------------------------------------------------
VK_API_TOKEN=vk1.a.weS-3ioDRR-cJu9rZwNiXog3I39On0RptOZnmRIP2g4xLwkbys-Ldn5Gt3c6okCI0quQPFjSX0wr2EqbH_4aR0Q3Egnw--fYBBEiRrNLBuKz0b9UTwphNhCriJo6kUeoul4M3M3KF8xVE2uJfuNVQbto1AlcjkfrX8LiuMFyClfJKpm-V4PfGMqH2l5qc1KerFSr8-D8fk9sk7puBIRRUQ
VK_API_VERSION=5.199
VK_GROUP_ID=239642245
# VK_PEER_ID_OFFSET is 2000000000 for group chats, 0 for direct user messages
VK_PEER_ID_OFFSET=0


# -----------------------------------------------------------------------------
# API Gateway (upstream service)
# The notification module fetches user and assignment data from the gateway
# when contact details are not embedded in the notification request.
# -----------------------------------------------------------------------------
API_GATEWAY_BASE_URL=http://localhost:8000
API_GATEWAY_TIMEOUT=10.0


# -----------------------------------------------------------------------------
# Application server
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO
TEMPLATES_DIR=templates
